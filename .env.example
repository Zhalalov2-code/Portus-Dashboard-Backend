# Скопируйте этот файл в .env и заполните реальными значениями.
# .env не должен попадать в git — он уже добавлен в .gitignore.

# --- База данных ---
# Для Docker используй DB_HOST=db (имя сервиса в docker-compose)
DB_HOST=db
DB_NAME=Portus_Managemend
DB_USER=Portus_User
DB_PASS=Portus_pass
DB_ROOT_PASS=Portus_root_pass

# --- CORS ---
# Точный адрес фронтенда (без слэша на конце).
# В проде НЕЛЬЗЯ оставлять "*"
ALLOWED_ORIGIN=https://portus-management.netlify.app

# --- Окружение ---
# production -> ошибки скрыты от клиента, только логируются
APP_ENV=production

# --- Порт (опционально) ---
# Порт, на котором будет доступен API снаружи контейнера
APP_PORT=8888
