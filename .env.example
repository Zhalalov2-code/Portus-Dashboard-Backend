# Скопируйте этот файл в .env (в той же папке) и заполните реальными значениями.
# .env не должен попадать в git — он уже добавлен в .gitignore.

# --- База данных ---
DB_HOST=localhost
DB_NAME=portusapp1
DB_USER=root
DB_PASS=root

# --- CORS ---
# Точный адрес фронтенда (без слэша на конце), который должен иметь доступ к API.
# В проде НЕЛЬЗЯ оставлять "*" — иначе API открыт для запросов с любого сайта.
ALLOWED_ORIGIN=http://localhost:3000

# --- Окружение ---
# development -> подробные ошибки PHP в ответе (для отладки на локали)
# production  -> ошибки скрыты от клиента, только логируются
APP_ENV=development
